{
  "name": "public-parks-backend",
  "version": "0.0.1",
  "private": true,
  "description": "Backend for the Public Recreation Facility Management Platform (Addis Ababa).",
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "node -r tsx test/integration/run-integration.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "typecheck": "tsc --noEmit --project tsconfig.test.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node -r tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "docs:generate": "APP_NODE_ENV=development DB_PRIMARY_URL=postgres://p:p@localhost:5432/p APP_ENABLE_DOCS=true node -r tsx src/docs/generate-openapi.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.1.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
